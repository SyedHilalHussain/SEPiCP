# Copy to .env and adjust. CI/CD / IIS: set these as pipeline or app settings secrets.
MYSQL_DATABASE=sepicp_db
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=127.0.0.1
# 3306 = default MySQL; 3307 = common XAMPP MariaDB port
MYSQL_PORT=3306

# Default app user (JWT login: email + password). Set DEFAULT_USER_SEED=false in production.
DEFAULT_USER_SEED=true
DEFAULT_USER_EMAIL=admin@sepicp.local
DEFAULT_USER_USERNAME=admin
DEFAULT_USER_PASSWORD=ChangeMe_LocalOnly
DEFAULT_USER_IS_STAFF=true
DEFAULT_USER_IS_SUPERUSER=true

# --- Production (IIS under /SEPiCP) ---
# DJANGO_DEBUG=false
# DJANGO_SECRET_KEY=use-a-long-random-string
# Include 127.0.0.1 if you test Waitress on this machine (Host header 127.0.0.1:port).
# ALLOWED_HOSTS=portal.nedscholars.org,localhost,127.0.0.1
# CSRF_TRUSTED_ORIGINS=https://portal.nedscholars.org
# DJANGO_FORCE_SCRIPT_NAME=/SEPiCP
# DJANGO_STATIC_URL=/SEPiCP/static/
# CORS_ALLOWED_ORIGINS=https://portal.nedscholars.org
# DEFAULT_USER_SEED=false
