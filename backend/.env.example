# Copy to .env and adjust. CI/CD / IIS: set these as pipeline or app settings secrets.
MYSQL_DATABASE=sepicp_db
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=127.0.0.1
# 3306 = default MySQL; 3307 = common XAMPP MariaDB port
MYSQL_PORT=3306

# Default app user (JWT login: email + password). Set DEFAULT_USER_SEED=false in production.
DEFAULT_USER_SEED=true
DEFAULT_USER_EMAIL=admin@sepicp.local
DEFAULT_USER_USERNAME=admin
DEFAULT_USER_PASSWORD=ChangeMe_LocalOnly
DEFAULT_USER_IS_STAFF=true
DEFAULT_USER_IS_SUPERUSER=true
