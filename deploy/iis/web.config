<?xml version="1.0" encoding="utf-8"?>
<!--
  Place this file as: C:\inetpub\wwwroot\portal\SEPiCP\backend\web.config
  IIS: Add Application "SEPiCP" with physical path pointing to that same ...\SEPiCP\backend folder.

  Requires: IIS HttpPlatformHandler (install "IIS HttpPlatformHandler" from Microsoft / Web Platform Installer).
  Python venv must exist at ..\venv relative to backend (i.e. SEPiCP\venv).
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="httpPlatformHandler" path="*" verb="*" modules="httpPlatformHandler" resourceType="Unspecified" />
    </handlers>
    <httpPlatform processPath="C:\inetpub\wwwroot\portal\SEPiCP\venv\Scripts\python.exe"
                  arguments="-m waitress --listen=127.0.0.1:%HTTP_PLATFORM_PORT% backend.wsgi:application"
                  workingDirectory="C:\inetpub\wwwroot\portal\SEPiCP\backend"
                  stdoutLogEnabled="true"
                  stdoutLogFile="C:\inetpub\wwwroot\portal\SEPiCP\logs\stdout"
                  startupTimeLimit="120"
                  requestTimeout="00:10:00">
      <environmentVariables>
        <environmentVariable name="DJANGO_SETTINGS_MODULE" value="backend.settings" />
        <environmentVariable name="PYTHONUNBUFFERED" value="1" />
      </environmentVariables>
    </httpPlatform>
  </system.webServer>
</configuration>
